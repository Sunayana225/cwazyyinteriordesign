# ─── Required ────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Local:   postgres://postgres:password@localhost:5432/alveo
# Hosted:  use Neon, Supabase, Railway, etc.
DATABASE_URL=postgres://postgres:password@localhost:5432/alveo

# Secret used to sign JWT auth tokens (30-day expiry).
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-with-a-long-random-string

# ─── API server port (default 8080) ──────────────────────────────────────────
PORT=8080

# ─── Optional: analytics admin endpoint ──────────────────────────────────────
# Protects GET /api/events and the mention-ack PATCH endpoint.
# Set to any long random string. Leave blank to disable those endpoints.
# EVENTS_ADMIN_TOKEN=

# ─── Optional: outgoing email (quote sending) ────────────────────────────────
# Leave all blank to run without email — quote send will return { sent: false }.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@example.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=Alvéo <you@example.com>
