# ══════════════════════════════════════════════════════════════════════════════
#  Alvéo — Local Environment Configuration
#  Copy this file to .env and fill in the values before running `pnpm dev`.
#
#  Quick start:
#    1. cp .env.example .env
#    2. Set DATABASE_URL  (see section below)
#    3. Set JWT_SECRET    (run the one-liner in that section to generate one)
#    4. pnpm install && pnpm dev
#       → API server: http://localhost:8080
#       → Frontend:   http://localhost:3000
# ══════════════════════════════════════════════════════════════════════════════


# ── 1. DATABASE ───────────────────────────────────────────────────────────────
#
#  The app uses PostgreSQL. All tables are created automatically on first run
#  (no manual migrations needed).
#
#  Option A — Local Postgres (install from https://www.postgresql.org/download/)
#    Create the database first: createdb alveo
DATABASE_URL=postgres://postgres:password@localhost:5432/alveo
#
#  Option B — Free hosted Postgres (no local install required)
#    Neon    https://neon.tech        → free tier, copy the connection string
#    Supabase https://supabase.com   → free tier, Settings → Database → URI
#    Railway https://railway.app     → free trial, copy Postgres connection URL
#
#  Paste your hosted connection string here (replace the line above):
#  DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require


# ── 2. JWT AUTH SECRET ────────────────────────────────────────────────────────
#
#  Signs all login tokens (30-day expiry). Must be a long random string.
#  The server will refuse to start in production if this is missing or default.
#
#  Generate a secure value by running this in your terminal:
#    node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
#
JWT_SECRET=replace-with-a-long-random-string


# ── 3. API SERVER PORT ────────────────────────────────────────────────────────
#
#  Port the Express API server listens on.
#  The Vite frontend dev server automatically proxies /api/* to this port.
#  Change API_PORT in .env AND here if you need a different port.
#
PORT=8080


# ── 4. ANALYTICS ADMIN TOKEN (optional) ──────────────────────────────────────
#
#  Protects two admin-only endpoints:
#    GET  /api/events               — view raw analytics events
#    PATCH /api/design-comments     — bulk mention-read acknowledgement
#
#  Without this set, both endpoints return 401 Unauthorized.
#  Set it to any long random string (same generator as JWT_SECRET above).
#
#  EVENTS_ADMIN_TOKEN=replace-with-another-long-random-string


# ── 5. EMAIL / SMTP (optional) ────────────────────────────────────────────────
#
#  Used for sending PDF quote emails to clients (POST /api/quotes/send).
#  If left blank, the endpoint returns { "sent": false, "fallback": true }
#  instead of an error — the app works fine without email.
#
#  Free SMTP options:
#    Resend    https://resend.com      — 3,000 emails/month free, SMTP supported
#    Brevo     https://brevo.com       — 300 emails/day free
#    Mailgun   https://mailgun.com     — 100 emails/day free on Flex plan
#    Gmail     smtp.gmail.com:587      — use an App Password (not your login password)
#                                        https://myaccount.google.com/apppasswords
#
#  SMTP_HOST=smtp.example.com
#  SMTP_PORT=587
#  SMTP_SECURE=false          # set to true only for port 465 (SSL), not 587 (STARTTLS)
#  SMTP_USER=you@example.com
#  SMTP_PASS=your-smtp-password-or-app-password
#  SMTP_FROM=Alvéo <you@example.com>   # defaults to SMTP_USER if not set


# ── 6. FRONTEND FEATURE FLAGS (optional) ─────────────────────────────────────
#
#  Error monitoring webhook — POSTs a JSON payload when a runtime error occurs.
#  Any POST endpoint works (Slack incoming webhook, custom logger, etc.).
#  Leave blank to disable silently.
#
#  VITE_MONITORING_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz


# ── 7. FRONTEND DEV SERVER (set automatically by pnpm dev) ───────────────────
#
#  These are passed automatically when you run `pnpm dev` from the root.
#  You do not need to set them here — only override if you have port conflicts.
#
#  FRONTEND_PORT=3000    # default frontend port
#  API_PORT=8080         # must match PORT above; used by Vite proxy
