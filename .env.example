# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-random-secret

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email magic-link provider (optional)
EMAIL_SERVER=
EMAIL_FROM=

# Supabase persistence (optional)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DESIGNS_TABLE=designs

# Optional monitoring webhook for server-side error reporting
MONITORING_WEBHOOK_URL=

# Optional admin token to protect /api/events reads and /admin/analytics dashboard usage
EVENTS_ADMIN_TOKEN=
